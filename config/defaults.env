# Tinderbox defaults (edit before running tools/prepare-installer-media.sh)

# Jetson Linux / JetPack base (L4T) release
L4T_RELEASE="R36.5.0"

# Expected NVIDIA tarballs (stored locally in artifacts/nvidia/; NOT committed to git)
NVIDIA_BSP_TARBALL="Jetson_Linux_R36.5.0_aarch64.tbz2"
NVIDIA_ROOTFS_TARBALL="Tegra_Linux_Sample-Root-Filesystem_R36.5.0_aarch64.tbz2"

# Official NVIDIA URLs (used by tools/fetch-nvidia-artifacts.sh)
# This is the ONLY step that needs internet access. After this, everything runs offline/airgapped.
NVIDIA_RELEASE_PAGE_URL="https://developer.nvidia.com/embedded/jetson-linux-r365"
NVIDIA_TEGRA_LICENSE_URL="https://developer.download.nvidia.com/embedded/L4T/r36_Release_v5.0/release/Tegra_Software_License_Agreement-Tegra-Linux.txt"
NVIDIA_BSP_URL="https://developer.download.nvidia.com/embedded/L4T/r36_Release_v5.0/release/Jetson_Linux_R36.5.0_aarch64.tbz2"
NVIDIA_ROOTFS_URL="https://developer.download.nvidia.com/embedded/L4T/r36_Release_v5.0/release/Tegra_Linux_Sample-Root-Filesystem_R36.5.0_aarch64.tbz2"

# Default user to bake into rootfs (avoids OEM-config GUI)
# NOTE: change these for real deployments.
TINDERBOX_DEFAULT_USER="ourbox"
TINDERBOX_DEFAULT_PASS="ourbox"
TINDERBOX_HOSTNAME="tinderbox"

# NVMe roles (can be overridden interactively at flash time)
TINDERBOX_OS_NVME_DEFAULT="nvme0n1"
TINDERBOX_DATA_NVME_DEFAULT="nvme1n1"

# Installer-time diagnostics SSH contract (for --diagnose initrd sessions).
# Root/root automation remains in place; this adds a human diagnostics account.
OURBOX_VARIANT="${OURBOX_VARIANT:-prod}"
if [[ -z "${OURBOX_INSTALLER_SSH_MODE:-}" ]]; then
  case "$(printf '%s' "${OURBOX_VARIANT}" | tr '[:upper:]' '[:lower:]')" in
    dev|support|debug|diag|diagnostic|lab|labs) OURBOX_INSTALLER_SSH_MODE="both" ;;
    *) OURBOX_INSTALLER_SSH_MODE="key" ;;
  esac
fi
OURBOX_INSTALLER_SSH_USER="ourbox-installer"
OURBOX_INSTALLER_SSH_PASSWORD_HASH='$6$ourboxinstall$GgJGorVZ2X.yl0cQk8yIqYDawhEuB47d9m.k9t9HP1afvwC3ALmMxTDtKT2NjDBMqkUOVzvm7LK2ZHxBt2KxH1'
OURBOX_INSTALLER_SSH_AUTHORIZED_KEYS=""
OURBOX_INSTALLER_SSH_ALLOW_ROOT="1"
